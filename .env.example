# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# Only the anon key belongs here. The service-role key and any OAuth client
# secrets must NEVER appear in this file or anywhere under src/.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AniList OAuth (Phase 6). The client ID is public (it only builds the
# authorize URL); the client SECRET and the token encryption key are Edge
# Function secrets and must never appear here or under src/. Leave empty to
# hide the "Link AniList" button.
VITE_ANILIST_CLIENT_ID=

# Optional. Leave empty to disable Sentry locally.
VITE_SENTRY_DSN=
