# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# Only the anon key belongs here. The service-role key and any OAuth client
# secrets must NEVER appear in this file or anywhere under src/.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. Leave empty to disable Sentry locally.
VITE_SENTRY_DSN=
